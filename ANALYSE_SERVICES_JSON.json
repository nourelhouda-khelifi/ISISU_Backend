        },
        {
          "method": "getSessionResults",
          "returnType": "List<ScoreCompetence>",
          "parameters": [
            {
              "type": "SessionTest",
              "name": "session"
            }
          ],
          "description": "Récupérer résultats finals"
        },
        {
          "method": "abandonSession",
          "returnType": "void",
