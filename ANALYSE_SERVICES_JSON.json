          "parameters": [
            {
              "type": "Utilisateur",
              "name": "utilisateur"
            }
          ],
          "description": "Créer nouvelle session pour un étudiant (ÉTAPE 1)"
        },
        {
          "method": "getCurrentSession",
          "returnType": "Optional<SessionTest>",
          "parameters": [
            {
              "type": "Utilisateur",
              "name": "utilisateur"
            }
          ],
          "description": "Récupérer la session courante d'un étudiant avec vérification timeout (ÉTAPE 2)"
        },
        {
          "method": "getNextQuestion",
          "returnType": "Optional<QuestionSession>",
          "parameters": [
            {
              "type": "SessionTest",
              "name": "session"
            }
          ],
          "description": "Récupérer la prochaine question non répondue (ÉTAPE 3)"
        },
        {
          "method": "submitAnswer",
          "returnType": "void",
          "parameters": [
            {
              "type": "SessionTest",
              "name": "session"
            },
            {
              "type": "QuestionSession",
              "name": "questionSession"
            },
            {
              "type": "ReponseEtudiant",
              "name": "response"
            }
          ],
          "description": "Traiter réponse d'étudiant avec validation et algorithme adaptatif (ÉTAPE 4)"
