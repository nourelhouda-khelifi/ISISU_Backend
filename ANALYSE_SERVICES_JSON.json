              "type": "QuestionSession",
              "name": "currentQuestion"
            },
            {
              "type": "ReponseEtudiant",
              "name": "response"
            }
          ],
          "description": "Analyser la réponse à la question courante et déterminer la prochaine question"
        },
        {
          "method": "countDetectedLacunes",
          "returnType": "int",
          "parameters": [
            {
              "type": "SessionTest",
              "name": "session"
            }
          ],
          "description": "Compter les lacunes détectées pour la session"
        },
        {
          "method": "countCompletedCompetences",
          "returnType": "int",
          "parameters": [
            {
              "type": "SessionTest",
              "name": "session"
            }
          ],
          "description": "Compter les compétences complètement évaluées"
        }
      ]
    },
    "SessionTestService": {
      "package": "com.example.demo.evaluation.service",
      "public_methods": [
